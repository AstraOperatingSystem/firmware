{
	"version": 10,
	"cmakeMinimumRequired": {
		"major": 4,
		"minor": 2,
		"patch": 1
	},
	"configurePresets": [
		{
			"name": "default",
			"displayName": "Default Config",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build",
			"toolchainFile": "cmake/TC-stm32f412zq.cmake"
		},
		{
			"name": "with-asn1scc",
			"displayName": "With ASN1SCC",
			"inherits": "default",
			"cacheVariables": {
				"ASN1SCC": "/opt/asn1scc/asn1scc"
			}
		}
	],
	"buildPresets": [
		{
			"name": "default",
			"configurePreset": "default"
		}
	]
}
